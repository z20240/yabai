yabai -m signal --add event=window_created action="sh ~/.config/yabai/scripts/stack_to_binary.sh $YABAI_WINDOW_ID"
yabai -m signal --add event=application_activated action="sh ~/.config/yabai/scripts/stack_to_binary.sh $YABAI_PROCESS_ID"
