#!/usr/bin/env sh
# YABAI STUFF

# Scripting addition must be injected as root (Dock.app). yabai itself stays a
# normal user process — it cannot run `yabai --load-sa` without sudo/root.
#
# Configure passwordless sudo once so the service never prompts for a password:
#   sudo visudo -f /etc/sudoers.d/yabai
#   peiningli ALL=(root) NOPASSWD: /opt/homebrew/bin/yabai --load-sa
#   sudo chmod 0440 /etc/sudoers.d/yabai
#
# Verify: sudo -n yabai --load-sa   (must succeed silently)
# https://github.com/koekeishiya/yabai/wiki/Installing-yabai-(latest-release)

yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa"
sudo yabai --load-sa

# Window rules — register and apply before layout bsp (required since yabai v7)
# manage=off: yabai ignores tiling. sub-layer=normal: opt out of v7 auto layer
# (v7 puts tiled windows on sub-layer=below and floats on normal → floats always on top).
# float system preferences. Most of these just diable Yabai form resizing them.
yabai -m rule --add app="Gifski" manage=off sub-layer=normal
yabai -m rule --add app=LINE manage=off sub-layer=normal
yabai -m rule --add app="System Preferences" manage=off sub-layer=normal
yabai -m rule --add app="System Settings" manage=off sub-layer=normal
yabai -m rule --add app="ygo|YGO" manage=off sub-layer=normal
yabai -m rule --add app="System Information" manage=off sub-layer=normal
yabai -m rule --add app="Activity Monitor" manage=off sub-layer=normal
yabai -m rule --add app="Hammerspoon" manage=off sub-layer=normal
yabai -m rule --add app="Finder" manage=off sub-layer=normal
yabai -m rule --add app="Calculator" manage=off sub-layer=normal
# https://www.cockos.com/licecap/
yabai -m rule --add app="licecap" manage=off sub-layer=normal
yabai -m rule --add app="Alfred Preferences" manage=off sub-layer=normal
yabai -m rule --add app="Disk Utility" manage=off sub-layer=normal
yabai -m rule --add app="Path Finder" manage=off sub-layer=normal
yabai -m rule --add app="TeamViewer" manage=off sub-layer=normal
yabai -m rule --add app="AppCleaner" manage=off sub-layer=normal
yabai -m rule --add app="iStat Menus" manage=off sub-layer=normal
yabai -m rule --add app="iStat Menus" manage=off sub-layer=normal
yabai -m rule --add app="Flux" manage=off sub-layer=normal
yabai -m rule --add app="Time Out" manage=off sub-layer=normal
yabai -m rule --add app="perl_client_app" manage=off sub-layer=normal
yabai -m rule --add app="CiscoSparkHelper" manage=off sub-layer=normal
yabai -m rule --add app="MyCard" manage=off sub-layer=normal
yabai -m rule --add app="TradingView" manage=off sub-layer=normal
yabai -m rule --add app="Vivaldi" manage=off sub-layer=normal
yabai -m rule --add app="Simulator" manage=off sub-layer=normal
yabai -m rule --add app="qemu-system-aarch64" manage=off sub-layer=normal
yabai -m rule --add app="installer" manage=off sub-layer=normal
yabai -m rule --add app="YGO Omega" manage=off sub-layer=normal
yabai -m rule --add app="Telegram" manage=off sub-layer=normal
yabai -m rule --add app=".*" sub-layer=normal

yabai -m rule --apply

## global settings
yabai -m config external_bar                 off
yabai -m config mouse_follows_focus          off
yabai -m config focus_follows_mouse          off
## New window spawns to the right if vertical split, or bottom if horizontal split
yabai -m config window_placement             second_child
## v7 removed window_topmost; stacking is controlled via sub-layer rules above
## example: show shadows only for floating windows
yabai -m config window_shadow                on
yabai -m config window_opacity               off
yabai -m config window_opacity_duration      0.0
yabai -m config active_window_opacity        1.0
yabai -m config normal_window_opacity        0.90
yabai -m config window_border                off          # (on | off)
yabai -m config window_border_width          6
yabai -m config active_window_border_color   0xff775759
yabai -m config normal_window_border_color   0xff555555
yabai -m config insert_feedback_color        0xffd75f5f
yabai -m config auto_balance                 on
yabai -m config split_ratio                  0.50
## set mouse interaction modifier key (default: fn)
yabai -m config mouse_modifier               fn
# set modifier + left-click drag to resize window (default: move)
yabai -m config mouse_action1                move
# set modifier + right-click drag to resize window (default: resize)
yabai -m config mouse_action2                resize
yabai -m config mouse_drop_action            stack

# general space settings
# bsp or float (default: bsp)
yabai -m config layout                       bsp

# # add 0 padding to the top and 0 padding to the bottom of every space located on the main display
# yabai -m config external_bar all:0:0
# yabai -m config external_bar main:20:0

## Change how yabai looks (the padding is the space between the window and the screen edge)
yabai -m config top_padding                  12
yabai -m config bottom_padding               12
yabai -m config left_padding                 24
yabai -m config right_padding                24
# set gap between each windows
yabai -m config window_gap                   8

# My custom space names for my 3 monitor setup. These names are used in some of my scripts.
yabai -m space 1 --label one
yabai -m space 2 --label two
yabai -m space 3 --label three
yabai -m space 4 --label four
yabai -m space 5 --label five
yabai -m space 6 --label six
yabai -m space 9 --label nine

# find ~/Library/Parallels/Applications\ Menus/ -maxdepth 3 -type f | awk -F'/' '{ print $NF; }' | awk '{$1=$1};1' | sort | uniq | tr "\n" "\0" | xargs -0 -I{} yabai -m rule --add app="^{}\$" title=".*" manage=on

## general space settings
# yabai -m config focused_border_skip_floating  1
# yabai -m config --space 3 layout             float

# signals
# yabai -m signal --add event=window_destroyed action="yabai -m query --windows --window &> /dev/null || yabai -m window --focus mouse"
# yabai -m signal --add event=space_changed action="yabai -m window --focus $(yabai -m query --windows --window | jq ".id")"
# yabai -m signal --add event=application_terminated action="yabai -m query --windows --window &> /dev/null || yabai -m window --focus mouse"

# testing signals
# yabai -m signal --add event=window_destroyed action="terminal-notifier -message 'window_destroyed'"
# yabai -m signal --add event=application_terminated action="terminal-notifier -message 'application_terminated'"
# yabai -m signal --add event=window_focused action="yabai -m window --toggle zoom-fullscreen"

## If I close the active window, focus on any other visible window.
yabai -m signal --add event=window_destroyed action="bash ~/.config/yabai/scripts/windowFocusOnDestroy.sh"

# yabai -m signal --add event=space_changed action="export CUR_ACTIVE_APP=\"iTerm2\""

echo "yabai configuration loaded.."

#END
